### 유형별 적립포인트 등록 1
POST http://localhost:10344/users/pointType
Content-Type: application/json

{
  "typeName": "회원가입",
  "earningPoint": 5000,
  "earningRate": 1,
  "gradeName": "일반"
}

### 유형별 적립포인트 등록 2
POST http://localhost:10344/users/pointType
Content-Type: application/json

{
  "typeName": "리뷰작성",
  "earningPoint": 500,
  "earningRate": 1,
